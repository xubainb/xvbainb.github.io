    for bullet, attrs in pairs(originalBulletAttrs) do
        if attrs.Drag then bullet:SetAttribute("Drag", attrs.Drag) end
        if attrs.ProjectileDrop then bullet:SetAttribute("ProjectileDrop", attrs.ProjectileDrop) end
    end
end

